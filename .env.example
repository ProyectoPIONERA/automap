# =============================================================
#  AutoMap – Environment Configuration Template
#  Copy this file to .env and fill in your values.
# =============================================================

# ── LLM Provider ─────────────────────────────────────────────
# Options: lm_studio | comet
LLM_PROVIDER=lm_studio

# ── LM Studio ────────────────────────────────────────────────
# URL of your running LM Studio server
LM_STUDIO_URL=http://localhost:1234/v1

# ── Default model (used by ALL agents unless overridden below) ─
# Change this single variable to switch models for the whole pipeline.
LLM_MODEL_DEFAULT=qwen2.5-coder-14b-instruct

# ── Per-role model overrides (optional) ──────────────────────
# Uncomment and set to give a specific agent a different model.
#LLM_MODEL_SCHEMA=qwen2.5-coder-14b-instruct
#LLM_MODEL_MAPPER=qwen2.5-coder-14b-instruct
#LLM_MODEL_ALIGNMENT=qwen2.5-coder-14b-instruct
#LLM_MODEL_YARRRML=qwen2.5-coder-14b-instruct
#LLM_MODEL_CQ=qwen2.5-coder-14b-instruct
#LLM_MODEL_REFINER=qwen2.5-coder-14b-instruct

# ── Per-role temperature overrides (optional) ────────────────
# Lower = more deterministic. Code defaults: schema/mapper=0.3, refiner=0.2
#LLM_TEMP_SCHEMA=0.3
#LLM_TEMP_MAPPER=0.3
#LLM_TEMP_ALIGNMENT=0.2
#LLM_TEMP_YARRRML=0.3
#LLM_TEMP_CQ=0.2
#LLM_TEMP_REFINER=0.2

# ── Global timeout (seconds, 0 = use per-role defaults) ──────
#LLM_TIMEOUT=0

# ── For Debugging Comet API (only needed when LLM_PROVIDER=comet) ──────────
COMET_API_KEY=your_comet_api_key_here
# Available COMET models:
COMET_MODEL=claude-opus-4-6
#COMET_MODEL=gpt-5.2
#COMET_MODEL=gemini-3-pro-all
#COMET_MODEL=chatgpt-4o-latest

# ── LangSmith (optional – for tracing/monitoring) ────────────
LANGSMITH_API_KEY=your_langsmith_api_key_here

# ── Input paths ──────────────────────────────────────────────
INPUT_ONTOLOGY_PATH=data/input/your_dataset/ontology.ttl
INPUT_CSV_PATH=data/input/your_dataset/data.csv

# ── Base URI for generated KG resources ──────────────────────
#BASE_URI=http://example.com/